{
  "name": "zeitlin-publisher",
  "version": "1.1.0",
  "description": "Publicador de proyectos para zeitlindavid.com",
  "main": "main.js",
  "author": "David Zeitlin",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.zeitlin.publisher",
    "productName": "Zeitlin Publisher",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "lib/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "identity": "-",
      "hardenedRuntime": false
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "tus-js-client": "^4.1.0",
    "basic-ftp": "^5.0.5",
    "sharp": "^0.33.4",
    "electron-updater": "^6.1.8"
  }
}